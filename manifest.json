{
  "manifest_version": 3,
  "name": "Slack MathJax Renderer",
  "description": "Render \\(...\\), \\[...\\], and bussproofs proof trees in Slack Web.",
  "version": "0.1.4",

  "content_scripts": [
    {
      "matches": [
        "https://*.slack.com/*",
        "https://app.slack.com/*"
      ],
      "js": [
        "mathjax-config.js",
        "mathjax/tex-svg-full.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
