{
  "manifest_version": 3,
  "name": "Slack MathJax Renderer",
  "description": "Render \\(...\\) and \\[...\\] LaTeX expressions in Slack Web.",
  "version": "0.1.0",

  "content_scripts": [
    {
      "matches": [
        "https://*.slack.com/*"
      ],
      "js": [
        "mathjax-config.js",
        "mathjax/tex-svg-full.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
